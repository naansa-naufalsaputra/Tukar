PORT=8787
DEFAULT_MODEL=gemini-3.1-pro-preview
MODEL_ORDER=gemini-3.1-pro-preview,gemini-3-flash-preview,gemini-2.5-flash
REQUEST_TIMEOUT_MS=60000
MAX_RETRIES_PER_REQUEST=2
COOLDOWN_MS=900000
MAX_429_BEFORE_COOLDOWN=2
MAX_5XX_BEFORE_COOLDOWN=3

# Comma-separated provider names in preferred order.
PROVIDER_ORDER=oauth-main,key-primary,key-secondary

# Provider type: "apikey" or "oauth"
PROVIDER_OAUTH_MAIN_TYPE=oauth
PROVIDER_OAUTH_MAIN_TOKEN=

PROVIDER_KEY_PRIMARY_TYPE=apikey
PROVIDER_KEY_PRIMARY_TOKEN=

PROVIDER_KEY_SECONDARY_TYPE=apikey
PROVIDER_KEY_SECONDARY_TOKEN=

# Optional soft budget guard (0-100). If exceeded, provider is deprioritized.
PROVIDER_OAUTH_MAIN_BUDGET_USED_PCT=0
PROVIDER_KEY_PRIMARY_BUDGET_USED_PCT=0
PROVIDER_KEY_SECONDARY_BUDGET_USED_PCT=0
