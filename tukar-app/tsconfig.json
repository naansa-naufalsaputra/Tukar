{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "incremental": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "src/app.d.ts",
    "nativewind-env.d.ts"
  ]
}
